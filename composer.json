{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.2",
        "askedio/laravel-soft-cascade": "^11.0",
        "fakerphp/faker": "^1.9.1",
        "guzzlehttp/guzzle": "^7.0.1",
        "intervention/image": "^3.0",
        "intervention/image-laravel": "^1.0",
        "kolydart/common": "dev-master",
        "kolydart/laravel": "dev-master",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9",
        "laravel/ui": "^4.0",
        "sentry/sentry-laravel": "^4.3",
        "spatie/laravel-activitylog": "^4.8",
        "yajra/laravel-datatables-oracle": "^11.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "*",
        "barryvdh/laravel-ide-helper": "*",
        "beyondcode/laravel-query-detector": "^2.3",
        "brianium/paratest": "^7.0",
        "jasonmccreary/laravel-test-assertions": "^2.1",
        "laravel/boost": "^1.0",
        "mockery/mockery": "^1.4.2",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^10.5",
        "roave/security-advisories": "dev-latest",
        "spatie/laravel-ignition": "^2.0",
        "symfony/thanks": "^1.2"
    },
    "autoload": {
        "classmap": [],
        "exclude-from-classmap": [],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "[ $COMPOSER_DEV_MODE -eq 0 ] || php artisan ide-helper:generate",
            "[ $COMPOSER_DEV_MODE -eq 0 ] || php artisan ide-helper:models --nowrite"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "symfony/thanks": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}